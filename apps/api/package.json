{
  "name": "@kaget/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "types": "./src/app.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc && bun build ./src/index.ts --target=bun --minify --outfile=./dist/index.js --external=better-auth --external=@better-auth/* --external=drizzle-orm",
    "start": "bun run ./dist/index.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:generate": "bunx --bun auth@latest generate --config ./src/index.ts --output ./src/db/schema/auth.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/zod-validator": "0.8.0",
    "better-auth": "1.6.14",
    "drizzle-orm": "0.45.2",
    "hono": "catalog:",
    "nanoid": "catalog:",
    "pino": "^10.3.1",
    "postgres": "3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@hono/cli": "^0.1.10",
    "@types/bun": "1.3.3",
    "@types/node": "catalog:",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
