{
  "name": "kaget",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "workspaces": {
    "packages": ["apps/*"],
    "catalog": {
      "@types/node": "^20.11.17",
      "hono": "^4.10.5",
      "nanoid": "^5.0.8",
      "typescript": "^5.8.3",
      "zod": "^4.1.12"
    }
  },
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "biome check .",
    "lint": "biome lint",
    "format": "biome check --write .",
    "prepare": "lefthook install",
    "release": "release-it"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "lefthook": "^2.1.5",
    "release-it": "^18.1.1",
    "turbo": "^2.6.1"
  },
  "release-it": {
    "git": {
      "commitMessage": "release: v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "${version}",
      "autoGenerate": true,
      "web": true
    }
  }
}
