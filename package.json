{
  "name": "kaget",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "workspaces": {
    "packages": ["apps/*"],
    "catalog": {
      "@types/node": "24.12.4",
      "hono": "4.12.23",
      "nanoid": "5.1.11",
      "typescript": "6.0.3",
      "vitest": "3.1.4",
      "zod": "4.4.3"
    }
  },
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "biome check .",
    "lint": "biome lint",
    "format": "biome check --write .",
    "prepare": "lefthook install",
    "release": "release-it"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "lefthook": "2.1.9",
    "release-it": "20.2.0",
    "turbo": "2.9.16",
    "typescript": "catalog:"
  },
  "overrides": {
    "esbuild": "0.28.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "release: v${version}"
    },
    "github": {
      "release": true,
      "releaseName": "${version}",
      "autoGenerate": true,
      "web": true
    }
  }
}
